# Copy this file to .env and fill in real values. Never commit .env.

# Stripe secret key (starts with sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret (starts with whsec_...) — you get this
# when you create the webhook endpoint in the Stripe Dashboard, or from
# `stripe listen` when testing locally.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# The public URL of the MARKETING SITE (where index.html, success.html,
# and cancel.html are hosted) — Stripe redirects here after payment.
SITE_URL=https://your-site-domain.example

# Comma-separated list of origins allowed to call this API from the
# browser. Use your site's real domain(s) in production. "*" allows any
# origin (fine for local testing, not recommended for production).
CORS_ORIGIN=*

# Price per person (in whole euros) for the custom "choose your own
# dates" booking path. The fixed departure's price lives in
# config/departures.json instead.
CUSTOM_PRICE_PER_PERSON=1450

# Basic auth credentials to view /admin (the booking record).
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_to_something_strong

# Port the server listens on.
PORT=4242

# Optional: where the SQLite file is written. Defaults to ./data/bookings.db
# DB_PATH=/data/bookings.db
